NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# For database scripts (migrate/cleanup)
SUPABASE_URL=https://your-project.supabase.co

# Auth/session (set to a long random string)
NEXTAUTH_SECRET=change-me

# Twilio SMS/MMS
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number

# Public app URL (Twilio fetches .vcf from this). Use production URL.
APP_URL=https://your-app.vercel.app

# Development only: override SMS recipient for testing
# TWILIO_TEST_RECIPIENT_PHONE=+15005550006
