# Integration test credentials — copy this to .env.test.local
# Fill in values from `npm run db:status` after running `npm run db:start`
#
# The local Supabase anon and service_role keys are the same every time,
# so you usually only need to set this up once.

NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon key from: npm run db:status>
SUPABASE_SERVICE_ROLE_KEY=<service_role key from: npm run db:status>
SUPABASE_URL=http://localhost:54321
NEXTAUTH_SECRET=test-secret-local
